<?xml version="1.0" encoding="utf-8"?>
<!--
  Permit plain HTTP (cleartext) ONLY to local development hosts. Android 9+
  blocks cleartext by default; this scopes the exception to dev addresses so
  production traffic to real domains still requires HTTPS.

  10.0.2.2  = the host machine as seen from the Android emulator (your PC's
              localhost). For a physical device, add your PC's LAN IP here.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
